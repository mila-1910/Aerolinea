        <main class="contenido-principal">

            <!-- TÍTULO -->
            <div class="saludo">
                <h2>📍 Ubicaciones</h2>
                <p>Gestión de destinos disponibles</p>
            </div>
            <div style="display:flex; gap:15px; margin-bottom:20px;">
                <input type="text" placeholder="Buscar ciudad..."
                       style="padding:10px; border:1px solid #ddd; border-radius:8px; flex:1;">

                <button class="btn-accion">Buscar</button>
            </div>

            <!-- BOTÓN AGREGAR -->
            <div style="margin-bottom:20px;">
                <button class="btn-accion">+ Agregar Ubicación</button>
            </div>


            <!-- TABLA DE UBICACIONES -->
            <table class="tabla-reservas-agente" style="margin-bottom:40px;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ciudad</th>
                        <th>País</th>
                        <th>Aeropuerto</th>
                        <th>Acciones</th>
