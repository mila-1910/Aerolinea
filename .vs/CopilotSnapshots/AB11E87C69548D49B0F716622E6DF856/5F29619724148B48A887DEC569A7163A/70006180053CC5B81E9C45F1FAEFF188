                    <div class="avatar">KM</div>
                    <span>Kamila Marin</span>
                    <span class="flecha">▼</span>
                </div>
                <ul class="dropdown">
                    <li><a href="#" title="Ver mi información">Mi Perfil</a></li>
                    <li><a href="#" class="cerrar-sesion" title="Cerrar sesión">Cerrar Sesión</a></li>
                </ul>
            </div>
        </div>
