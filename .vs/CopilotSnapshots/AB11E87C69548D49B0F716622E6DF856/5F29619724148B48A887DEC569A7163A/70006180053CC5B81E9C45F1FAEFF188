                        </td>
                    </tr>
                    <tr>
                        <td>#UB-003</td>
                        <td>Miami</td>
                        <td>Estados Unidos</td>
                        <td>Miami Intl</td>
                        <td>
                            <a href="#" class="btn-accion">Editar</a>
                        </td>
                    </tr>
                </tbody>
            </table>

        </main>
