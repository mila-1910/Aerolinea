                </a>
                <a href="paquetes.html" class="menu-item">
                    <span class="menu-icono"><i class="fas fa-box" style="color: #d4af37;"></i></span>
                    <span class="menu-texto">Paquetes</span>
                </a>
                <a href="ubicaciones.html" class="menu-item active">
                    <span class="menu-icono"><i class="fas fa-map-marker-alt" style="color: #d4af37;"></i></span>
