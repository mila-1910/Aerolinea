        <!-- Parte superior del footer -->
        <div class="footer-top">

            <!-- Logo y descripción -->
            <div class="footer-columna">
                <img src="../../imagenes/logo-dorado.png" alt="ELARIS" height="60">
                <p>Conectamos personas con destinos. Volamos hacia lo que importa.</p>
            </div>

            <!-- Contacto -->
            <div class="footer-columna">
                <h4>Contacto</h4>
                <p><i class="fa-regular fa-envelope footer-icono"></i> contacto@elaris.com</p>
                <p><i class="fa-solid fa-phone footer-icono"></i> +57 300 123 4567</p>
                <p><i class="fa-solid fa-location-dot footer-icono"></i> Tuluá, Colombia</p>
            </div>

            <!-- Redes sociales -->
