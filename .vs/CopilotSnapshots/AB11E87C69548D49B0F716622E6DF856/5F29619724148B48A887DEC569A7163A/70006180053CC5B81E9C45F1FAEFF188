</head>

<body>

    <!-- ============================================
         NAVBAR SUPERIOR
         ============================================ -->
    <nav class="navbar-agente">
        <div class="navbar-logo">
            <img src="../../imagenes/logo-dorado.png" alt="ELARIS Logo">
            <span class="logo-texto">ELARIS</span>
        </div>

        <div class="navbar-centro">
            <span class="panel-texto">Ubicaciones</span>
            <span class="badge-agente">ADMINISTRADOR</span>
        </div>

        <div class="navbar-right">
            <div class="notificaciones" title="Notificaciones">
                <span class="icono"><i class="fas fa-bell" style="color: #d4af37;"></i></span>
                <span class="badge">3</span>
            </div>

            <div class="navbar-perfil">
